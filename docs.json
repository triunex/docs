              "models/action-schema",
              "models/action-request",
              "models/action-response",
              "models/app-summary",
              "models/verification"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "Python SDK",
            "pages": [
              "sdk/python/overview",
              "sdk/python/installation",
              "sdk/python/client",
              "sdk/python/session",
              "sdk/python/clr",
              "sdk/python/jvm",
              "sdk/python/streaming",
              "sdk/python/error-handling"
